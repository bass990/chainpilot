# Copy this file to .env and fill in your own values.
# The real .env is gitignored, this template is committed so the project
# is reproducible by anyone who clones the repo.

# Anthropic API key for the orchestrator and specialist agents.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional, Slack webhook for the Communications agent to post outbound updates.
# Leave blank to disable Slack posting.
SLACK_WEBHOOK_URL=

# Optional, SMTP credentials for the Communications agent to send emails.
# Leave blank to disable email sending.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
